# Local development configuration for careai-platform.
# Copy to .env for local overrides. Never commit real .env files or secrets.

ENVIRONMENT=local
LOG_LEVEL=INFO

POSTGRES_USER=careai
POSTGRES_PASSWORD=careai_dev_password
POSTGRES_DB=careai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://careai:careai_dev_password@localhost:5432/careai
CONTROL_PLANE_DATABASE_URL=postgresql+psycopg://careai:careai_dev_password@localhost:5432/careai

REDIS_URL=redis://localhost:6379/0

MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_BACKEND_STORE_URI=postgresql://careai:careai_dev_password@postgres:5432/careai
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts

AZURITE_BLOB_ENDPOINT=http://localhost:10000/devstoreaccount1
AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true

CONTROL_PLANE_API_URL=http://localhost:8000
INFERENCE_SERVICE_URL=http://localhost:8001
RAG_SERVICE_URL=http://localhost:8002
WEB_CONSOLE_URL=http://localhost:3000

CLAIMS_RISK_MODEL_URI=
CLAIMS_RISK_MODEL_METADATA_PATH=
CLAIMS_RISK_FEATURE_VERSION=claims-risk-features-v1
CLAIMS_RISK_MAX_FEATURE_AGE_MINUTES=1440
INFERENCE_AUDIT_ENABLED=true

SYNTHETIC_DATA_SEED=20260614
